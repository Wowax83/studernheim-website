generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Verein {
  id            Int      @id @default(autoincrement())
  name          String
  beschreibung  String
  bild          String?   // optional (für später)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Termin {
  id            Int      @id @default(autoincrement())
  titel         String
  datum         DateTime
  ort           String
  beschreibung  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Visit {
  id        Int      @id @default(1)
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
}
